---
---

<section class="business">
  <div class="business__inner container container--padded">
    <!-- Centered header -->
    <div class="business__header">
      <p class="business__label">Per le Aziende</p>
      <h2 class="business__heading">
        Proteggi la vista dei tuoi dipendenti. Noi pensiamo a tutto.
      </h2>
      <p class="business__subtext">
        Soluzioni su misura per professionisti, artigiani e imprese di ogni settore.
      </p>
    </div>

    <!-- 3 service cards -->
    <div class="business__cards">
      <!-- Card 1 -->
      <article class="business__card">
        <div class="business__card-top">
          <svg class="business__card-icon" viewBox="0 0 40 40" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
            <!-- Safety/protective glasses -->
            <path d="M4 16C4 16 6 13 10 13H13C14.5 13 15.5 14 16.5 14.5C17.5 15 18.5 15 20 15C21.5 15 22.5 15 23.5 14.5C24.5 14 25.5 13 27 13H30C34 13 36 16 36 16" stroke="var(--color-primary)" stroke-width="2.2" stroke-linecap="round"/>
            <rect x="4" y="16" width="12" height="8" rx="3" stroke="var(--color-primary)" stroke-width="2.2"/>
            <rect x="24" y="16" width="12" height="8" rx="3" stroke="var(--color-primary)" stroke-width="2.2"/>
            <line x1="16" y1="20" x2="24" y2="20" stroke="var(--color-primary)" stroke-width="2.2" stroke-linecap="round"/>
            <line x1="4" y1="19" x2="1" y2="21" stroke="var(--color-primary)" stroke-width="2.2" stroke-linecap="round"/>
            <line x1="36" y1="19" x2="39" y2="21" stroke="var(--color-primary)" stroke-width="2.2" stroke-linecap="round"/>
          </svg>
          <img
            src="/assets/images/icon-send.svg"
            alt=""
            width="28"
            height="28"
            class="business__card-arrow"
          />
        </div>
        <div class="business__card-body">
          <h3 class="business__card-title">Occhiali da Lavoro e Protezione</h3>
          <p class="business__card-desc">
            DPI conformi alle normative per ambienti industriali e cantieri. Montature robuste, lenti
            antigraffio e filtranti per sicurezza e comfort.
          </p>
        </div>
      </article>

      <!-- Card 2 -->
      <article class="business__card">
        <div class="business__card-top">
          <svg class="business__card-icon" viewBox="0 0 40 40" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
            <!-- Monitor + eye (blue light filter) -->
            <rect x="6" y="6" width="28" height="19" rx="3" stroke="var(--color-primary)" stroke-width="2.2"/>
            <line x1="14" y1="25" x2="26" y2="25" stroke="var(--color-primary)" stroke-width="2.2" stroke-linecap="round"/>
            <line x1="20" y1="25" x2="20" y2="30" stroke="var(--color-primary)" stroke-width="2.2" stroke-linecap="round"/>
            <line x1="15" y1="30" x2="25" y2="30" stroke="var(--color-primary)" stroke-width="2.2" stroke-linecap="round"/>
            <path d="M12 15.5C12 15.5 14.5 12 20 12C25.5 12 28 15.5 28 15.5C28 15.5 25.5 19 20 19C14.5 19 12 15.5 12 15.5Z" stroke="var(--color-primary)" stroke-width="2" stroke-linejoin="round"/>
            <circle cx="20" cy="15.5" r="2.2" fill="var(--color-primary)"/>
          </svg>
          <img
            src="/assets/images/icon-send.svg"
            alt=""
            width="28"
            height="28"
            class="business__card-arrow"
          />
        </div>
        <div class="business__card-body">
          <h3 class="business__card-title">Occhiali Anti-Luce Blu</h3>
          <p class="business__card-desc">
            Per chi trascorre molte ore davanti a monitor e schermi digitali. Lenti con filtro luce
            blu per ridurre l'affaticamento visivo e proteggere la retina.
          </p>
        </div>
      </article>

      <!-- Card 3 -->
      <article class="business__card">
        <div class="business__card-top">
          <svg class="business__card-icon" viewBox="0 0 40 40" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
            <!-- Handshake (convenzione aziendale) -->
            <path d="M4 22L10 16H16L20 13L24 16H30L36 22" stroke="var(--color-primary)" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"/>
            <path d="M10 16L14 20L18 18L22 21L26 19L30 22" stroke="var(--color-primary)" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"/>
            <path d="M4 22L10 28" stroke="var(--color-primary)" stroke-width="2.2" stroke-linecap="round"/>
            <path d="M36 22L30 28" stroke="var(--color-primary)" stroke-width="2.2" stroke-linecap="round"/>
            <path d="M10 28C10 28 14 32 20 32C26 32 30 28 30 28" stroke="var(--color-primary)" stroke-width="2.2" stroke-linecap="round"/>
          </svg>
          <img
            src="/assets/images/icon-send.svg"
            alt=""
            width="28"
            height="28"
            class="business__card-arrow"
          />
        </div>
        <div class="business__card-body">
          <h3 class="business__card-title">Convenzioni Aziendali</h3>
          <p class="business__card-desc">
            Accordi dedicati per aziende e dipendenti: tariffe agevolate, priorità nelle prenotazioni
            e assistenza diretta su misura.
          </p>
        </div>
      </article>
    </div>
  </div>
</section>

<style>
  .business {
    width: 100%;
    background-color: var(--color-bg-white);
  }

  .business__inner {
    display: flex;
    flex-direction: column;
    gap: 3.75em;
    padding-block: 3.75em;
  }

  /* Header */
  .business__header {
    display: flex;
    flex-direction: column;
    gap: 1em;
    align-items: center;
    text-align: center;
  }

  .business__label {
    font-family: var(--font-body);
    font-size: 1.25em;
    font-weight: 400;
    line-height: 1.2;
    color: var(--color-primary);
    text-transform: uppercase;
  }

  .business__heading {
    font-family: var(--font-heading);
    font-size: 3.5em;
    font-weight: 500;
    line-height: 1.1;
    color: var(--color-text-dark);
    letter-spacing: -1.68px;
    max-width: 14.57em; /* 816px / 56px */
  }

  .business__subtext {
    font-family: var(--font-body);
    font-size: 1em;
    font-weight: 400;
    line-height: 1.5;
    color: var(--color-text-body);
    max-width: 37em; /* 592px */
  }

  /* Cards grid */
  .business__cards {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.5em;
  }

  .business__card {
    background-color: var(--color-bg-white);
    border: 1px solid var(--color-border);
    padding: 2.125em;
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    gap: 4.375em;
  }

  .business__card-top {
    display: flex;
    align-items: center;
    justify-content: space-between;
  }

  .business__card-icon {
    width: 2.5em;
    height: 2.5em;
    flex-shrink: 0;
  }

  .business__card-arrow {
    width: 1.75em;
    height: 1.75em;
    transform: rotate(180deg) scaleY(-1);
    flex-shrink: 0;
  }

  .business__card-body {
    display: flex;
    flex-direction: column;
    gap: 0.625em;
  }

  .business__card-title {
    font-family: var(--font-heading);
    font-size: 1.5em;
    font-weight: 500;
    line-height: 1.333;
    color: var(--color-primary);
    letter-spacing: -1.44px;
  }

  .business__card-desc {
    font-family: var(--font-body);
    font-size: 1em;
    font-weight: 400;
    line-height: 1.5;
    color: var(--color-text-body);
  }

  /* ===================== Responsive ===================== */
  @media (max-width: 991px) {
    .business__cards {
      grid-template-columns: repeat(2, 1fr);
    }

    .business__heading {
      font-size: 2.5em;
    }
  }

  @media (max-width: 767px) {
    .business__cards {
      grid-template-columns: 1fr;
    }

    .business__card {
      gap: 2em;
    }

    .business__heading {
      font-size: 2em;
    }
  }
</style>
